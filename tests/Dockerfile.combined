FROM node:20-slim AS pkg-builder

WORKDIR /pkg
COPY package.json tsconfig.json ./
COPY src/ src/
RUN npm install && npm run build

FROM node:20-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tests/package.json ./
RUN npm install

COPY tests/ .

# Install the built package from the first stage
COPY --from=pkg-builder /pkg/dist/ node_modules/@pamfilico/nextjs-url-tabs/dist/
COPY --from=pkg-builder /pkg/package.json node_modules/@pamfilico/nextjs-url-tabs/package.json

RUN npm run build

EXPOSE 3098
CMD ["npm", "start"]
