FROM node:20-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package source
COPY src/ /pkg-src/

# Copy test app
COPY tests/package.json ./
RUN npm install

COPY tests/ .

# Point the webpack alias to the copied source
# next.config.ts resolves ../src -> /pkg-src via override
RUN sed -i 's|"../src"|"/pkg-src"|g' next.config.ts

RUN npm run build

EXPOSE 3098
CMD ["npm", "start"]
